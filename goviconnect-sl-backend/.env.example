# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/goviconnect?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Translate API (for translating dynamic content between English and Sinhala)
# Get a free API key at https://console.cloud.google.com/ → Cloud Translation API
# Leave empty to disable translation (app falls back to original text gracefully).
GOOGLE_TRANSLATE_API_KEY=

# ML Service
ML_SERVICE_URL=http://localhost:5000

# WFP VAM Data Bridges API (for live Sri Lanka crop market prices)
# Register free at https://developers.wfp.org/ to get your API key.
# Leave empty to use HARTI/DOA historical average prices as fallback.
WFP_API_KEY=

# Server
PORT=3000
NODE_ENV=development
